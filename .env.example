# Copy this file to .env and fill your real keys.
# Do NOT commit .env.

# LLM provider (recommended)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3-flash-preview
GEMINI_MODEL=gemini-3-flash-preview

# Required secret
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Runtime responsiveness (interactive-friendly defaults)
LLM_MAX_RETRIES=0
LLM_RETRY_BASE_SEC=1.0
LLM_HTTP_TIMEOUT_SEC=10
LLM_MAX_TOTAL_SEC=30
